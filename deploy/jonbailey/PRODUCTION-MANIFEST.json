{
  "version": "3.0.0",
  "updated": "2026-07-23",
  "codename": "OMEGA ASCENDANT",
  "share": {
    "commandHub": "https://sentinel.example.com",
    "edgeStatus": "https://example.com/.__dm/status",
    "protectedSite": "https://example.com",
    "repository": "https://github.com/Pitchfork-and-Torch/ghost-continuum"
  },
  "cloudflare": {
    "accountId": "<YOUR_ACCOUNT_ID>",
    "zoneId": "<YOUR_ZONE_ID>",
    "edgeWorker": "<your-worker-name>",
    "upstream": "<your-pages-dev-hostname>",
    "kvNamespaceId": "<YOUR_KV_NAMESPACE_ID>",
    "kvTitle": "DM_OBSERVER",
    "routes": [
      "example.com/*",
      "www.example.com/*"
    ],
    "tunnel": {
      "id": "<YOUR_TUNNEL_ID>",
      "name": "ghost-continuum-hub",
      "hostname": "sentinel.example.com",
      "localService": "http://127.0.0.1:30000"
    },
    "access": {
      "team": "<your-team>.cloudflareaccess.com",
      "appId": "<YOUR_ACCESS_APP_ID>",
      "appName": "Ghost Continuum Command Hub",
      "aud": "<YOUR_ACCESS_AUD>",
      "allowedEmail": "operator@example.com"
    }
  },
  "local": {
    "configPath": "%USERPROFILE%\\.ghost-continuum\\config.json",
    "tunnelTokenPath": "%USERPROFILE%\\.cloudflared\\ghost-continuum-hub.token",
    "hubPort": 30000,
    "ghostLanPort": 29999
  }
}