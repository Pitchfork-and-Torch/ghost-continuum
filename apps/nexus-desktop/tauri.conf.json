{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DM-Sentinel Nexus",
  "version": "1.0.0",
  "identifier": "com.pitchfork.ghost-continuum",
  "build": {
    "devUrl": "http://127.0.0.1:30000",
    "frontendDist": "../../packages/hub-ui/public"
  },
  "app": {
    "windows": [
      {
        "title": "DM-Sentinel — Command Nexus",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:30000 https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' http://127.0.0.1:30000 https://cdn.jsdelivr.net"
    }
  }
}